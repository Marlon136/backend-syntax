# ========== BASE DE DATOS ==========
# Ejemplo con Neon PostgreSQL (recomendado para nube)
DATABASE_URL='postgresql://user:password@ep-xxxx.c-x.us-east-1.aws.neon.tech/dbname?sslmode=require&channel_binding=require'

# ========== JWT - AUTENTICACIÓN ==========
JWT_SECRET= cambia-esto-en-produccion
JWT_EXPIRES_IN=1d

# ========== STRIPE - CONFIGURACIÓN ==========
# Obtén estos valores en: https://dashboard.stripe.com/apikeys
# - Para pruebas usa sk_test_... / pk_test_...
# - Para producción usa sk_live_... / pk_live_...
# Secret Key (SK) - NO compartir. Ejemplo: sk_live_XXXXXXXX
STRIPE_SECRET_KEY=sk_test_tu_clave_secreta_aqui_o_sk_live_en_produccion
# Webhook Signing Secret (WHSEC) - obtenido al crear el webhook en el dashboard o con Stripe CLI
STRIPE_WEBHOOK_SECRET=whsec_tu_webhook_secret_aqui

# Optional: use Price IDs from Stripe Dashboard for production (recommended)
# Create Products + Prices in Stripe and paste their Price IDs here (e.g. price_1Lt...)
STRIPE_PRICE_ID_JAVA=
STRIPE_PRICE_ID_PYTHON=
STRIPE_PRICE_ID_JS=

# ========== URLs ==========
# URL pública del frontend que usará CORS y redirecciones.
FRONTEND_URL=http://localhost:3000
# URL pública de la aplicación. Se usa como fallback para Stripe cuando no hay origin header.
APP_URL=http://localhost:3000

# ========== ENTORNO ==========
NODE_ENV=development
PORT=3001
